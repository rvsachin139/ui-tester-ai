{
  "name": "ui-tester-ai-backend",
  "version": "1.0.0",
  "description": "NestJS backend for UI Tester AI",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:cli": "node dist/cli/runner.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/database/typeorm.config.ts",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate -d src/database/typeorm.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mysql2": "^3.22.5",
    "playwright": "^1.61.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
